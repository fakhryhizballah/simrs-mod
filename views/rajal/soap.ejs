  <div class="bg-white p-4 rounded-lg shadow-sm border border-gray-200 mb-6">
            <button onclick="history.back()" class="mb-6 flex items-center bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-md shadow-sm transition duration-150">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Kembali
        </button>
        <h2 class="text-lg font-semibold text-gray-800 mb-4 flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 text-blue-600" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
            </svg>
            Filter Riwayat Pemeriksaan (CPPT)
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-5 gap-4 items-end">
            <div>
                <label class="block text-xs font-medium text-gray-700 mb-1">No. Rawat</label>
                <input type="text" id="filter-no-rawat" class="w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm p-2 border">
            </div>
            <div>
                <label class="block text-xs font-medium text-gray-700 mb-1">No. RM</label>
                <input type="text" id="filter-no-rm" class="w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm p-2 border" readonly>
            </div>
            <div>
                <label class="block text-xs font-medium text-gray-700 mb-1">Nama Pasien</label>
                <input type="text" id="filter-nama" class="w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm p-2 border" readonly>
            </div>
            <div>
                <label class="block text-xs font-medium text-gray-700 mb-1">Status Lanjut</label>
                <select id="filter-status" class="w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm p-2 border bg-white">
                    <option value="Ralan">Ralan</option>
                </select>
            </div>
            <div>
                <label class="block text-xs font-medium text-gray-700 mb-1">Kode Poli</label>
                <input type="text" id="filter-kd-poli" class="w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm p-2 border" value="" readonly>
            </div>
            <div>
                <button id="btn-cari" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-md shadow-sm transition duration-150">
                    Cari Riwayat
                </button>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-12 gap-6">
        
        <!-- KOLOM KIRI: FORM INPUT / EDIT -->
        <div class="xl:col-span-7 bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden flex flex-col min-h-[600px]">
            <div class="bg-gray-50 px-4 py-3 border-b border-gray-200 flex justify-between items-center">
                <h3 class="font-semibold text-gray-800" id="form-title">Input Data Pemeriksaan (CPPT)</h3>
                <button type="button" id="btn-reset" class="text-sm text-red-600 hover:text-red-800 font-medium hidden">Batal Edit</button>
            </div>
            
            <div class="p-4 flex-grow overflow-y-auto">
                <form id="form-pemeriksaan" class="space-y-6">
                    <!-- Info Dasar & Waktu -->
                    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                        <div class="md:col-span-2">
                            <label class="block text-xs font-medium text-gray-700 mb-1">No. Rawat Target</label>
                            <input type="text" id="no_rawat" class="w-full border-gray-300 bg-gray-50 rounded-md shadow-sm sm:text-sm p-2 border" readonly>
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-700 mb-1">Tanggal</label>
                            <input type="date" id="tgl_perawatan" class="w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm p-2 border" readonly>
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-700 mb-1">Jam</label>
                            <input type="time" id="jam_rawat" step="1" class="w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm p-2 border" readonly>
                        </div>
                    </div>

                    <!-- Tanda Vital -->
                    <div>
                        <h4 class="text-sm font-semibold text-gray-600 border-b pb-1 mb-3">Tanda Vital & Fisik</h4>
                        <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
                            <div>
                                <label class="block text-xs text-gray-600 mb-1">Suhu (°C)</label>
                                <input type="text" id="suhu_tubuh" class="w-full border-gray-300 rounded-md shadow-sm p-2 border sm:text-sm" required>
                            </div>
                            <div>
                                <label class="block text-xs text-gray-600 mb-1">Tensi (mmHg)</label>
                                <input type="text" id="tensi" class="w-full border-gray-300 rounded-md shadow-sm p-2 border sm:text-sm" required placeholder="120/80">
                            </div>
                            <div>
                                <label class="block text-xs text-gray-600 mb-1">Nadi (x/mnt)</label>
                                <input type="text" id="nadi" class="w-full border-gray-300 rounded-md shadow-sm p-2 border sm:text-sm" required>
                            </div>
                            <div>
                                <label class="block text-xs text-gray-600 mb-1">Respirasi (x/mnt)</label>
                                <input type="text" id="respirasi" class="w-full border-gray-300 rounded-md shadow-sm p-2 border sm:text-sm" required>
                            </div>
                            <div>
                                <label class="block text-xs text-gray-600 mb-1">SpO2 (%)</label>
                                <input type="text" id="spo2" class="w-full border-gray-300 rounded-md shadow-sm p-2 border sm:text-sm" required>
                            </div>
                            <div>
                                <label class="block text-xs text-gray-600 mb-1">Tinggi (cm)</label>
                                <input type="text" id="tinggi" class="w-full border-gray-300 rounded-md shadow-sm p-2 border sm:text-sm" required>
                            </div>
                            <div>
                                <label class="block text-xs text-gray-600 mb-1">Berat (Kg)</label>
                                <input type="text" id="berat" class="w-full border-gray-300 rounded-md shadow-sm p-2 border sm:text-sm" required>
                            </div>
                            <div>
                                <label class="block text-xs text-gray-600 mb-1">GCS</label>
                                <input type="text" id="gcs" class="w-full border-gray-300 rounded-md shadow-sm p-2 border sm:text-sm" required placeholder="E,V,M">
                            </div>
                            <div>
                                <label class="block text-xs text-gray-600 mb-1">L. Perut (cm)</label>
                                <input type="text" id="lingkar_perut" class="w-full border-gray-300 rounded-md shadow-sm p-2 border sm:text-sm" required>
                            </div>
                            <div>
                                <label class="block text-xs text-gray-600 mb-1">Kesadaran</label>
                                <select id="kesadaran" class="w-full border-gray-300 rounded-md shadow-sm p-2 border sm:text-sm bg-white">
                                    <option value="Compos Mentis">Compos Mentis</option>
                                    <option value="Somnolence">Somnolence</option>
                                    <option value="Sopor">Sopor</option>
                                    <option value="Coma">Coma</option>
                                    <option value="Apatis">Apatis</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- SOAP -->
                    <div>
                        <h4 class="text-sm font-semibold text-gray-600 border-b pb-1 mb-3">Subjektif, Objektif, Asesmen & Plan (SOAP)</h4>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-xs font-medium text-gray-700 mb-1">Subjektif / Keluhan</label>
                                <textarea id="keluhan" rows="3" class="w-full border-gray-300 rounded-md shadow-sm p-2 border sm:text-sm" required></textarea>
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-gray-700 mb-1">Objektif / Pemeriksaan Fisik</label>
                                <textarea id="pemeriksaan" rows="3" class="w-full border-gray-300 rounded-md shadow-sm p-2 border sm:text-sm" required></textarea>
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-gray-700 mb-1">Asesmen / Penilaian</label>
                                <textarea id="penilaian" rows="2" class="w-full border-gray-300 rounded-md shadow-sm p-2 border sm:text-sm" required></textarea>
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-gray-700 mb-1">Plan / RTL (Rencana Tindak Lanjut)</label>
                                <textarea id="rtl" rows="2" class="w-full border-gray-300 rounded-md shadow-sm p-2 border sm:text-sm" required></textarea>
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-gray-700 mb-1">Instruksi Medis</label>
                                <textarea id="instruksi" rows="2" class="w-full border-gray-300 rounded-md shadow-sm p-2 border sm:text-sm" required></textarea>
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-gray-700 mb-1">Evaluasi</label>
                                <textarea id="evaluasi" rows="2" class="w-full border-gray-300 rounded-md shadow-sm p-2 border sm:text-sm" required></textarea>
                            </div>
                        </div>
                    </div>

                    <!-- Alergi & Petugas -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-medium text-gray-700 mb-1">Riwayat Alergi</label>
                            <input type="text" id="alergi" class="w-full border-gray-300 rounded-md shadow-sm p-2 border sm:text-sm" placeholder="Tidak ada alergi..." required>
                        </div>
                        <div class="grid grid-cols-2 gap-1">
                            <div>
                                <label class="block text-xs font-medium text-gray-700 mb-1">NIP Petugas/Dokter</label>
                                <input type="text" id="nip" class="w-full border-gray-300 rounded-md shadow-sm p-2 border sm:text-sm" readonly>
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-gray-700 mb-1">Nama Petugas/Dokter</label>
                                <input type="text" id="nama_pegawai" class="w-full border-gray-300 rounded-md shadow-sm p-2 border sm:text-sm" readonly>
                            </div>
                        </div>
                    </div>
                    <input type="hidden" id="status" value="1">
                </form>
            </div>
            
            <div class="bg-gray-50 px-4 py-3 border-t border-gray-200 flex justify-end">
                <button type="button" id="btn-simpan" class="bg-green-600 hover:bg-green-700 text-white font-medium py-2 px-6 rounded-md shadow-sm transition duration-150 flex items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" />
                    </svg>
                    Simpan Data
                </button>
            </div>
        </div>

        <!-- KOLOM KANAN: BERKAS DAN RIWAYAT -->
        <div class="xl:col-span-5 grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div class="bg-white rounded-lg shadow-sm border border-gray-200 flex flex-col min-h-[400px]">
                <div class="bg-gray-50 px-4 py-3 border-b border-gray-200 flex justify-between items-center">
                    <h3 class="font-semibold text-gray-800">Berkas digital</h3>
                </div>
                
                <div class="p-4 flex-grow overflow-y-auto bg-gray-50" id="container-berkas">
                    <!-- Status Loading -->
                    <div id="loading-berkas" class="text-center py-10 hidden">
                        <svg class="animate-spin h-8 w-8 text-blue-600 mx-auto mb-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                        <p class="text-sm text-gray-500">Memuat data riwayat...</p>
                    </div>
                    <!-- Kontainer List Card -->
                    <div class="mt-2 border-t border-gray-200">
                        <h4 class="text-sm font-semibold text-gray-600 mb-1">Dokumen Penunjang (Gambar/PDF)</h4>
                        <p class="text-xs text-gray-500 mb-3">Daftar file lampiran dari riwayat pemeriksaan pasien.</p>
                        <!-- Kontainer yang akan diisi oleh JavaScript -->
                        <div id="container-lampiran" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
                            <!-- Loading skeleton -->
                            <div class="animate-pulse bg-gray-200 rounded-lg h-32 w-full"></div>
                            <div class="animate-pulse bg-gray-200 rounded-lg h-32 w-full"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- KOLOM KANAN: LIST RIWAYAT -->
            <div class="bg-white rounded-lg shadow-sm border border-gray-200 flex flex-col min-h-[400px]">
                <div class="bg-gray-50 px-4 py-3 border-b border-gray-200 flex justify-between items-center">
                    <h3 class="font-semibold text-gray-800">Riwayat Pemeriksaan</h3>
                    <span class="bg-blue-100 text-blue-800 text-xs font-medium px-2.5 py-0.5 rounded-full" id="count-riwayat">0 Data</span>
                </div>
                
                <div class="p-4 flex-grow overflow-y-auto bg-gray-50" id="container-riwayat">
                    <!-- Status Loading -->
                    <div id="loading-riwayat" class="text-center py-10 hidden">
                        <svg class="animate-spin h-8 w-8 text-blue-600 mx-auto mb-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                        <p class="text-sm text-gray-500">Memuat data riwayat...</p>
                    </div>

                    <!-- Kontainer List Card -->
                    <div id="list-riwayat" class="space-y-4">
                        <!-- Data riwayat akan di-render di sini oleh JavaScript -->
                    </div>
                </div>
            </div>
        </div>

    </div>