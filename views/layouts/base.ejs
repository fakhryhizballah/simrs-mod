<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Aplikasi' %></title>
    <link rel="manifest" href="/manifest.json">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50">
    <%- body %>

    <!-- PWA Install Popup -->
    <div id="install-popup" class="fixed bottom-4 left-4 right-4 md:left-auto md:right-4 md:w-96 bg-white p-4 rounded-lg shadow-lg border hidden z-50">
        <div class="flex items-center justify-between mb-2">
            <h3 class="text-lg font-semibold">Install SIMRS App</h3>
            <button id="close-popup" class="text-gray-500 hover:text-gray-700">&times;</button>
        </div>
        <p class="text-sm text-gray-600 mb-4">Install aplikasi SIMRS untuk pengalaman yang lebih baik dengan akses offline.</p>
        <div class="flex space-x-2">
            <button id="install-btn" class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">Install</button>
            <button id="dismiss-btn" class="bg-gray-300 text-gray-700 px-4 py-2 rounded hover:bg-gray-400">Nanti</button>
        </div>
    </div>

    <script src="/asset/js/pwa.js"></script>
</body>
</html>